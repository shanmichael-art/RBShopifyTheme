{% comment %} Royal Beardsmen — Identity / "Who This Is For" Section {% endcomment %}
<style>
  .rb-id {
    background: #111111;
    padding: 110px 40px;
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .rb-id__inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .rb-id__eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.30em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0 0 20px 0;
  }

  .rb-id__heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(34px, 4.5vw, 60px);
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 56px 0;
    letter-spacing: -0.02em;
    line-height: 1.08;
  }

  .rb-id__heading em {
    font-style: italic;
    color: rgba(255,255,255,0.55);
  }

  .rb-id__lines {
    list-style: none;
    margin: 0 0 56px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .rb-id__line {
    display: flex;
    align-items: baseline;
    gap: 20px;
    padding: 20px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .rb-id__line:first-child {
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .rb-id__line-mark {
    width: 20px;
    height: 1px;
    background: #c9a96e;
    flex-shrink: 0;
    margin-top: 10px;
  }

  .rb-id__line-text {
    font-family: 'Lato', sans-serif;
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.55;
    color: rgba(255,255,255,0.78);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .rb-id__cta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c9a96e;
    text-decoration: none;
    transition: gap 0.22s ease;
  }

  .rb-id__cta:hover {
    gap: 20px;
  }

  .rb-id__cta-line {
    width: 32px;
    height: 1px;
    background: #c9a96e;
    position: relative;
    transition: width 0.22s ease;
  }

  .rb-id__cta:hover .rb-id__cta-line {
    width: 44px;
  }

  .rb-id__cta-line::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -3px;
    width: 6px;
    height: 6px;
    border-right: 1px solid #c9a96e;
    border-top: 1px solid #c9a96e;
    transform: rotate(45deg);
  }

  @media screen and (max-width: 768px) {
    .rb-id { padding: 80px 24px; }
    .rb-id__line { gap: 16px; padding: 16px 0; }
    .rb-id__line-text { font-size: 15px; }
  }
</style>

<div class="rb-id index-section" data-section-id="{{ section.id }}" data-section-type="rb-identity">
  <div class="rb-id__inner">

    {% if section.settings.eyebrow != blank %}
      <p class="rb-id__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="rb-id__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ul class="rb-id__lines">
        {% for block in section.blocks %}
          <li class="rb-id__line" {{ block.shopify_attributes }}>
            <span class="rb-id__line-mark" aria-hidden="true"></span>
            <p class="rb-id__line-text">{{ block.settings.line | escape }}</p>
          </li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
      <a href="{{ section.settings.cta_link }}" class="rb-id__cta">
        {{ section.settings.cta_label | escape }}
        <span class="rb-id__cta-line" aria-hidden="true"></span>
      </a>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Who This Is For",
  "class": "rb-id-wrap",
  "max_blocks": 8,
  "settings": [
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow",  "default": "Who This Is For" },
    { "type": "textarea", "id": "heading", "label": "Heading",  "default": "This is for the man who." },
    { "type": "text",     "id": "cta_label", "label": "CTA label", "default": "Shop the Collection" },
    { "type": "url",      "id": "cta_link",  "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "line",
      "name": "Line",
      "settings": [
        { "type": "text", "id": "line", "label": "Line text", "default": "Grew a beard on purpose and takes care of it the same way" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Who This Is For",
      "category": "Custom",
      "blocks": [
        { "type": "line", "settings": { "line": "Grew a beard on purpose and takes care of it the same way" } },
        { "type": "line", "settings": { "line": "Wants a scent that actually means something, not just smells like soap" } },
        { "type": "line", "settings": { "line": "Knows the difference between cheap grooming products and the real thing" } },
        { "type": "line", "settings": { "line": "Holds himself to a standard in the gym, at work, in the mirror" } },
        { "type": "line", "settings": { "line": "Finishes what he starts" } },
        { "type": "line", "settings": { "line": "Understands that a well-kept beard is a statement, not vanity" } }
      ]
    }
  ]
}
{% endschema %}
