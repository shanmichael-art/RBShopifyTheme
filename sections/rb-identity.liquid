<div class="rb-identity" data-section-id="{{ section.id }}" data-section-type="rb-identity">
  <div class="wrapper">
    {% if section.settings.eyebrow != blank %}
      <p class="rb-identity-eyebrow">{{ section.settings.eyebrow | upcase | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="rb-identity-heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <ul class="rb-identity-list">
        {% for block in section.blocks %}
          <li {{ block.shopify_attributes }}>{{ block.settings.line | escape }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
      <a href="{{ section.settings.cta_link }}" class="rb-identity-cta">
        {{ section.settings.cta_label | escape }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Brand Identity",
  "class": "index-section rb-identity-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Who This Is For"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This is for the man who."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "line",
      "name": "List item",
      "settings": [
        {
          "type": "text",
          "id": "line",
          "label": "Line",
          "default": "Shows up with intention every day"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Identity",
      "category": "Custom",
      "blocks": [
        { "type": "line", "settings": { "line": "Shows up with intention — in the gym, at work, in the mirror" } },
        { "type": "line", "settings": { "line": "Understands that how you carry yourself says everything" } },
        { "type": "line", "settings": { "line": "Wants to smell like somewhere worth going" } },
        { "type": "line", "settings": { "line": "Finishes what he starts" } },
        { "type": "line", "settings": { "line": "Takes pride without taking himself too seriously" } },
        { "type": "line", "settings": { "line": "Grows a great beard and knows exactly what to put in it" } }
      ]
    }
  ]
}
{% endschema %}
