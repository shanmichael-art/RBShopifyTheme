{% comment %} Royal Beardsmen — Brand Manifesto / Statement Section {% endcomment %}
<style>
  .rb-manifesto {
    background: #0c0c0c;
    padding: 120px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .rb-manifesto::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(201,169,110,0.35));
  }

  .rb-manifesto::after {
    content: '';
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 60px;
    background: linear-gradient(to top, transparent, rgba(201,169,110,0.35));
  }

  .rb-manifesto__inner {
    max-width: 820px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .rb-manifesto__kicker {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.30em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0 0 36px 0;
    display: block;
  }

  .rb-manifesto__ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 40px;
  }

  .rb-manifesto__ornament-line {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: rgba(201,169,110,0.30);
  }

  .rb-manifesto__ornament-diamond {
    width: 6px;
    height: 6px;
    background: #c9a96e;
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .rb-manifesto__quote {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 700;
    line-height: 1.24;
    color: #ffffff;
    margin: 0 0 36px 0;
    letter-spacing: -0.01em;
    font-style: italic;
  }

  .rb-manifesto__sub {
    font-family: 'Lato', sans-serif;
    font-size: 14px;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.38);
    margin: 0;
    text-transform: uppercase;
  }

  @media screen and (max-width: 768px) {
    .rb-manifesto { padding: 88px 28px; }
    .rb-manifesto__quote { font-size: clamp(24px, 7vw, 38px); }
  }
</style>

<div class="rb-manifesto index-section" data-section-id="{{ section.id }}" data-section-type="rb-manifesto">
  <div class="rb-manifesto__inner">

    {% if section.settings.kicker != blank %}
      <span class="rb-manifesto__kicker">{{ section.settings.kicker | escape }}</span>
    {% endif %}

    <div class="rb-manifesto__ornament">
      <div class="rb-manifesto__ornament-line"></div>
      <div class="rb-manifesto__ornament-diamond"></div>
      <div class="rb-manifesto__ornament-line"></div>
    </div>

    {% if section.settings.quote != blank %}
      <p class="rb-manifesto__quote">&ldquo;{{ section.settings.quote | escape }}&rdquo;</p>
    {% endif %}

    {% if section.settings.sub != blank %}
      <p class="rb-manifesto__sub">{{ section.settings.sub | escape }}</p>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Brand Manifesto",
  "class": "rb-manifesto-wrap",
  "settings": [
    { "type": "text",     "id": "kicker", "label": "Eyebrow text", "default": "The Standard" },
    { "type": "textarea", "id": "quote",  "label": "Quote / statement", "default": "The difference between a good beard and a great one is about three minutes a day." },
    { "type": "text",     "id": "sub",    "label": "Sub text", "default": "Handcrafted in Spring Hill, Florida." }
  ],
  "presets": [{ "name": "Brand Manifesto", "category": "Custom" }]
}
{% endschema %}
