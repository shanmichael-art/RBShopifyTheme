<div class="rb-two-oz" data-section-id="{{ section.id }}" data-section-type="rb-two-oz">
  <div class="rb-two-oz-inner">
    <div class="rb-two-oz-number" aria-hidden="true">2oz</div>
    <div class="rb-two-oz-content">
      {% if section.settings.eyebrow != blank %}
        <p class="rb-two-oz-eyebrow">{{ section.settings.eyebrow | upcase | escape }}</p>
      {% endif %}
      {% if section.settings.headline != blank %}
        <h2 class="rb-two-oz-headline">{{ section.settings.headline | escape }}</h2>
      {% endif %}
      {% if section.settings.body != blank %}
        <p class="rb-two-oz-body">{{ section.settings.body | escape }}</p>
      {% endif %}
      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <a href="{{ section.settings.cta_link }}" class="rb-two-oz-cta">{{ section.settings.cta_label | escape }}</a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "2oz Differentiator",
  "class": "rb-two-oz-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "The Difference"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Twice the oil. Same price."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body copy",
      "default": "The industry standard is a 1oz bottle. Ours hold 2oz — same price, twice the product. We chose better ingredients over bigger margins. That's not a deal. That's just how we build things."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button text",
      "default": "Shop Beard Oils"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "2oz Differentiator",
      "category": "Custom"
    }
  ]
}
{% endschema %}
