{% comment %} Royal Beardsmen — Brand Differentiators / Pillars {% endcomment %}
<style>
  .rb-diff {
    background: #141414;
    padding: 80px 0;
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .rb-diff__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
    gap: 0;
  }

  .rb-diff__item {
    padding: 0 40px;
    border-right: 1px solid rgba(255,255,255,0.06);
    position: relative;
  }

  .rb-diff__item:first-child {
    padding-left: 0;
  }

  .rb-diff__item:last-child {
    border-right: none;
    padding-right: 0;
  }

  .rb-diff__num {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.20em;
    color: #c9a96e;
    margin: 0 0 16px 0;
    display: block;
  }

  .rb-diff__heading {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 12px 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .rb-diff__sub {
    font-family: 'Lato', sans-serif;
    font-size: 14px;
    line-height: 1.70;
    color: rgba(255,255,255,0.44);
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .rb-diff { padding: 64px 0; }
    .rb-diff__grid {
      grid-template-columns: repeat(2, 1fr);
      padding: 0 24px;
      gap: 40px 32px;
    }
    .rb-diff__item {
      padding: 0;
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding-bottom: 40px;
    }
    .rb-diff__item:nth-child(odd) { padding-right: 16px; }
    .rb-diff__item:nth-last-child(-n+2) { border-bottom: none; padding-bottom: 0; }
  }

  @media screen and (max-width: 430px) {
    .rb-diff__grid { grid-template-columns: 1fr; gap: 32px; }
    .rb-diff__item { padding: 0 !important; border-right: none; }
    .rb-diff__item:not(:last-child) { border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 32px !important; }
    .rb-diff__item:last-child { border-bottom: none; padding-bottom: 0 !important; }
  }
</style>

<div class="rb-diff index-section" data-section-id="{{ section.id }}" data-section-type="rb-differentiators">
  <div class="rb-diff__grid">
    {% for block in section.blocks %}
      <div class="rb-diff__item" {{ block.shopify_attributes }}>
        <span class="rb-diff__num">0{{ forloop.index }}</span>
        {% if block.settings.heading != blank %}
          <h3 class="rb-diff__heading">{{ block.settings.heading | escape }}</h3>
        {% endif %}
        {% if block.settings.sub != blank %}
          <p class="rb-diff__sub">{{ block.settings.sub | escape }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Brand Pillars",
  "class": "rb-diff-wrap",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "USA Handcrafted" },
        { "type": "text", "id": "sub",     "label": "Supporting text", "default": "Made in small batches, right here in the US." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Pillars",
      "category": "Custom",
      "blocks": [
        { "type": "pillar", "settings": { "heading": "Made in the USA", "sub": "Blended in Spring Hill, Florida. Not a warehouse. Not overseas. By people who actually use it." } },
        { "type": "pillar", "settings": { "heading": "All Natural", "sub": "Pure carrier oils. Organic botanicals. No synthetics, no fillers, nothing you can't pronounce." } },
        { "type": "pillar", "settings": { "heading": "Twice the Size", "sub": "Our oils come in 2oz bottles. The industry standard is 1oz. You're already ahead." } },
        { "type": "pillar", "settings": { "heading": "100% Backed", "sub": "Not satisfied? We fix it. No forms, no runaround — a straight answer and a real solution." } }
      ]
    }
  ]
}
{% endschema %}
