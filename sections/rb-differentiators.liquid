<div class="rb-differentiators" data-section-id="{{ section.id }}" data-section-type="rb-differentiators">
  <div class="wrapper">
    <div class="rb-diff-grid">
      {% for block in section.blocks %}
        <div class="rb-diff-item" {{ block.shopify_attributes }}>
          <h3 class="rb-diff-heading">{{ block.settings.heading | escape }}</h3>
          {% if block.settings.subtext != blank %}
            <p class="rb-diff-subtext">{{ block.settings.subtext | escape }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Brand Pillars",
  "class": "index-section rb-differentiators-section",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "USA Handcrafted"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Supporting text",
          "default": "Made in small batches, right here in the US."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Pillars",
      "category": "Custom",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "heading": "USA Handcrafted",
            "subtext": "Every product made in small batches, right here in the United States."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "heading": "All Natural",
            "subtext": "No fillers, no synthetics. Pure carrier oils and organic botanicals only."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "heading": "Satisfaction Guaranteed",
            "subtext": "If it is not right, we make it right. No questions, no hassle."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "heading": "Small Batch Quality",
            "subtext": "Crafted in small runs so every bottle meets the same high standard."
          }
        }
      ]
    }
  ]
}
{% endschema %}
