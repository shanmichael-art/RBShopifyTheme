<div class="rb-scent-nav" data-section-id="{{ section.id }}" data-section-type="rb-scent-nav">
  <div class="rb-scent-nav-track">
    {% for block in section.blocks %}
      {% if block.settings.link != blank %}
        <a href="{{ block.settings.link }}" class="rb-scent-nav-item" {{ block.shopify_attributes }}>
          {{ block.settings.name | escape }}
        </a>
      {% else %}
        <span class="rb-scent-nav-item" {{ block.shopify_attributes }}>
          {{ block.settings.name | escape }}
        </span>
      {% endif %}
      {% unless forloop.last %}
        <span class="rb-scent-nav-sep" aria-hidden="true">·</span>
      {% endunless %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Scent Navigation",
  "class": "rb-scent-nav-section",
  "max_blocks": 12,
  "settings": [],
  "blocks": [
    {
      "type": "scent",
      "name": "Scent",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Scent name",
          "default": "El Humidor"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection or product link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scent Navigation",
      "category": "Custom",
      "blocks": [
        { "type": "scent", "settings": { "name": "El Humidor" } },
        { "type": "scent", "settings": { "name": "Bonfire Brandy" } },
        { "type": "scent", "settings": { "name": "Dragon Spice" } },
        { "type": "scent", "settings": { "name": "Pinewood Forest" } },
        { "type": "scent", "settings": { "name": "King's Lagoon" } },
        { "type": "scent", "settings": { "name": "Cavalier" } },
        { "type": "scent", "settings": { "name": "Leisure" } },
        { "type": "scent", "settings": { "name": "Whiskey Glaze" } },
        { "type": "scent", "settings": { "name": "Vanguard" } },
        { "type": "scent", "settings": { "name": "Reign" } }
      ]
    }
  ]
}
{% endschema %}
