{% comment %}
  Royal Beardsmen — Bundle Offer Section
  High-converting bundle CTA with savings badge, includes list, and pricing.
  Links to a bundle product or collection.
{% endcomment %}

<section class="rb-section rb-bundle" data-section-id="{{ section.id }}" data-section-type="rb-bundle-offer">
  <div class="rb-container">

    <div class="rb-section-header rb-reveal">
      <span class="rb-label">{{ section.settings.label | default: 'Best Value' }}</span>
      <div class="rb-divider"></div>
      <h2>{{ section.settings.title | default: 'The Royal Kit' }}</h2>
      {% if section.settings.subtitle != blank %}
        <p>{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="rb-bundle__inner rb-reveal rb-reveal--delay-1">

      <div class="rb-bundle__visual">
        {% if section.settings.image %}
          <img
            src="{{ section.settings.image | image_url: width: 800, height: 1000, crop: 'center' }}"
            srcset="{{ section.settings.image | image_url: width: 600, height: 750, crop: 'center' }} 600w,
                    {{ section.settings.image | image_url: width: 800, height: 1000, crop: 'center' }} 800w"
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="{{ section.settings.title | escape }}"
            loading="lazy"
            width="800"
            height="1000"
          >
        {% else %}
          <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--rb-surface-3),var(--rb-surface-2));display:flex;align-items:center;justify-content:center;">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="var(--rb-border-light)" stroke-width="0.75" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          </div>
        {% endif %}
        <div class="rb-bundle__visual-overlay"></div>
        <div class="rb-bundle__savings-badge">
          <strong>{{ section.settings.savings_percent | default: '20%' }}</strong>
          <span>OFF</span>
        </div>
      </div>

      <div class="rb-bundle__offer">
        <span class="rb-label">{{ section.settings.offer_label | default: "What's Included" }}</span>
        <div class="rb-divider rb-divider--left"></div>

        <ul class="rb-bundle__includes">
          {% for block in section.blocks %}
            {% if block.type == 'item' %}
              <li {{ block.shopify_attributes }}>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                {{ block.settings.text }}
              </li>
            {% endif %}
          {% endfor %}
          {% if section.blocks.size == 0 %}
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              Premium Beard Oil (2 oz)
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              Conditioning Beard Balm (2 oz)
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              Beard &amp; Face Wash (4 oz)
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              Boar Bristle Beard Brush
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              Signature Gift Box Packaging
            </li>
          {% endif %}
        </ul>

        <div class="rb-bundle__pricing">
          <span class="rb-bundle__price-now">{{ section.settings.price_now | default: '$59.99' }}</span>
          {% if section.settings.price_was != blank %}
            <span class="rb-bundle__price-was">{{ section.settings.price_was }}</span>
          {% endif %}
          {% if section.settings.price_save != blank %}
            <span class="rb-bundle__price-save">Save {{ section.settings.price_save }}</span>
          {% endif %}
        </div>

        <a href="{{ section.settings.cta_url | default: '/collections/bundles' }}"
           class="rb-btn rb-btn--primary"
           style="font-size:0.8125rem;">
          {{ section.settings.cta_text | default: 'Build My Kit' }}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        {% if section.settings.guarantee_text != blank %}
          <p style="margin-top:1.25rem;font-family:var(--font-body);font-size:0.8rem;font-weight:300;color:var(--rb-text-dim);display:flex;align-items:center;gap:0.5rem;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--rb-success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {{ section.settings.guarantee_text }}
          </p>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "RB — Bundle Offer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "default": "Best Value"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "The Royal Kit"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Everything a king needs, curated in one complete grooming set."
    },
    {
      "type": "header",
      "content": "Bundle visual"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bundle image"
    },
    {
      "type": "text",
      "id": "savings_percent",
      "label": "Savings badge text",
      "default": "20%"
    },
    {
      "type": "header",
      "content": "Offer details"
    },
    {
      "type": "text",
      "id": "offer_label",
      "label": "Offer sub-label",
      "default": "What's Included"
    },
    {
      "type": "text",
      "id": "price_now",
      "label": "Current price",
      "default": "$59.99"
    },
    {
      "type": "text",
      "id": "price_was",
      "label": "Original price",
      "default": "$74.96"
    },
    {
      "type": "text",
      "id": "price_save",
      "label": "Savings amount",
      "default": "$14.97"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Build My Kit"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL",
      "default": "/collections/bundles"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee micro-copy",
      "default": "30-day money-back guarantee. Free shipping over $50."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Bundle Item",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Item description",
          "default": "Premium Beard Oil (2 oz)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RB — Bundle Offer",
      "category": "Royal Beardsmen",
      "blocks": [
        { "type": "item", "settings": { "text": "Premium Beard Oil (2 oz)" } },
        { "type": "item", "settings": { "text": "Conditioning Beard Balm (2 oz)" } },
        { "type": "item", "settings": { "text": "Beard & Face Wash (4 oz)" } },
        { "type": "item", "settings": { "text": "Boar Bristle Beard Brush" } },
        { "type": "item", "settings": { "text": "Signature Gift Box Packaging" } }
      ]
    }
  ]
}
{% endschema %}
