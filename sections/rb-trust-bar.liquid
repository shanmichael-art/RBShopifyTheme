{% comment %}
  Royal Beardsmen — Trust Bar
  4-icon strip for key value props. Sits directly below the hero.
{% endcomment %}

<div class="rb-section rb-trust-bar" data-section-id="{{ section.id }}" data-section-type="rb-trust-bar">
  <div class="rb-trust-bar__inner">

    <div class="rb-trust-item rb-reveal">
      <svg class="rb-trust-item__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/><path d="M12 5l7 7-7 7"/>
        <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
      </svg>
      <span class="rb-trust-item__text">{{ section.settings.item1 | default: 'Free Shipping $50+' }}</span>
    </div>

    <div class="rb-trust-item rb-reveal rb-reveal--delay-1">
      <svg class="rb-trust-item__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      <span class="rb-trust-item__text">{{ section.settings.item2 | default: '30-Day Guarantee' }}</span>
    </div>

    <div class="rb-trust-item rb-reveal rb-reveal--delay-2">
      <svg class="rb-trust-item__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span class="rb-trust-item__text">{{ section.settings.item3 | default: 'Handcrafted in USA' }}</span>
    </div>

    <div class="rb-trust-item rb-reveal rb-reveal--delay-3">
      <svg class="rb-trust-item__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
      <span class="rb-trust-item__text">{{ section.settings.item4 | default: 'All-Natural Ingredients' }}</span>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "RB — Trust Bar",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "item1",
      "label": "Trust item 1",
      "default": "Free Shipping $50+"
    },
    {
      "type": "text",
      "id": "item2",
      "label": "Trust item 2",
      "default": "30-Day Guarantee"
    },
    {
      "type": "text",
      "id": "item3",
      "label": "Trust item 3",
      "default": "Handcrafted in USA"
    },
    {
      "type": "text",
      "id": "item4",
      "label": "Trust item 4",
      "default": "All-Natural Ingredients"
    }
  ],
  "presets": [
    {
      "name": "RB — Trust Bar",
      "category": "Royal Beardsmen"
    }
  ]
}
{% endschema %}
