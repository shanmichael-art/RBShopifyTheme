<div class="rb-scent-grid" data-section-id="{{ section.id }}" data-section-type="rb-scent-grid">
  <div class="wrapper">
    <div class="rb-scent-grid-header">
      {% if section.settings.eyebrow != blank %}
        <p class="rb-scent-grid-eyebrow">{{ section.settings.eyebrow | upcase | escape }}</p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="rb-scent-grid-title">{{ section.settings.title | escape }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="rb-scent-grid-subtitle">{{ section.settings.subtitle | escape }}</p>
      {% endif %}
    </div>

    <div class="rb-scent-cards">
      {% for block in section.blocks %}
        {% comment %} Determine background source: image_picker > raw CDN url > CSS gradient {% endcomment %}
        {% assign has_image = false %}
        {% if block.settings.image != blank %}
          {% assign has_image = true %}
          {% assign card_img_url = block.settings.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}
        {% elsif block.settings.raw_image_url != blank %}
          {% assign has_image = true %}
          {% assign card_img_url = block.settings.raw_image_url %}
        {% endif %}

        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="rb-scent-card rb-scent-scheme--{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
        {% else %}
          <div class="rb-scent-card rb-scent-scheme--{{ block.settings.color_scheme }}" {{ block.shopify_attributes }}>
        {% endif %}

          {% if has_image %}
            {% if block.settings.image != blank %}
              <div class="rb-scent-card-bg lazyload"
                data-bgset="{{ card_img_url }}"
                data-sizes="auto"
                data-parent-fit="cover">
              </div>
            {% else %}
              <div class="rb-scent-card-bg" style="background-image: url('{{ card_img_url }}'); background-size: cover; background-position: center;"></div>
            {% endif %}
          {% else %}
            <div class="rb-scent-card-bg rb-scent-card-gradient"></div>
          {% endif %}

          <div class="rb-scent-card-overlay"></div>

          <div class="rb-scent-card-content">
            {% if block.settings.product_type != blank %}
              <p class="rb-scent-card-type">{{ block.settings.product_type | upcase | escape }}</p>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="rb-scent-card-title">{{ block.settings.title | escape }}</h3>
            {% endif %}
            {% if block.settings.tagline != blank %}
              <p class="rb-scent-card-tagline">{{ block.settings.tagline | escape }}</p>
            {% endif %}
            {% if block.settings.notes != blank %}
              <p class="rb-scent-card-notes">{{ block.settings.notes | escape }}</p>
            {% endif %}
            {% if block.settings.cta_label != blank %}
              <span class="rb-scent-card-cta">{{ block.settings.cta_label | escape }} &rarr;</span>
            {% endif %}
          </div>

        {% if block.settings.link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Scent Collection Grid",
  "class": "index-section rb-scent-grid-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "The Line"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section heading",
      "default": "Find Your Scent"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Every scent is a world. Find the one that's yours."
    }
  ],
  "blocks": [
    {
      "type": "scent",
      "name": "Scent Card",
      "settings": [
        {
          "type": "select",
          "id": "color_scheme",
          "label": "Background color scheme (when no image)",
          "options": [
            { "value": "forest", "label": "Forest (Great Wilderness)" },
            { "value": "amber", "label": "Amber (Legends)" },
            { "value": "slate", "label": "Slate (Leisure)" },
            { "value": "smoke", "label": "Smoke (Grief)" },
            { "value": "dark", "label": "Dark (default)" }
          ],
          "default": "dark"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card background image (from Theme Files)"
        },
        {
          "type": "text",
          "id": "raw_image_url",
          "label": "Card background image URL (direct CDN link)",
          "info": "Use this for images uploaded via Shopify Files. Paste the full CDN URL."
        },
        {
          "type": "text",
          "id": "product_type",
          "label": "Product type label",
          "default": "Beard Oil"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Scent / Collection name",
          "default": "Great Wilderness"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "One-line tagline",
          "default": "The one that started it all."
        },
        {
          "type": "text",
          "id": "notes",
          "label": "Scent notes",
          "default": "Cedar · Pine · Cold Morning Air"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Link label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scent Collection Grid",
      "category": "Custom"
    }
  ]
}
{% endschema %}
