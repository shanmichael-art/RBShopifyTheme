{% comment %} Royal Beardsmen — Scent Collection Grid {% endcomment %}
<style>
  .rb-sg {
    background: #111111;
    padding: 100px 0 0;
  }

  .rb-sg__header {
    text-align: center;
    padding: 0 40px 64px;
    max-width: 680px;
    margin: 0 auto;
  }

  .rb-sg__eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.30em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0 0 18px 0;
  }

  .rb-sg__heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(30px, 3.5vw, 48px);
    font-weight: 700;
    line-height: 1.15;
    color: #ffffff;
    margin: 0 0 16px 0;
    letter-spacing: -0.01em;
  }

  .rb-sg__subtitle {
    font-family: 'Lato', sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255,255,255,0.50);
    margin: 0;
  }

  .rb-sg__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .rb-sg__card {
    position: relative;
    min-height: 520px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    text-decoration: none;
    cursor: pointer;
  }

  .rb-sg__card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transition: transform 0.60s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .rb-sg__card:hover .rb-sg__card-bg {
    transform: scale(1.07);
  }

  /* Color scheme fallbacks */
  .rb-sg__card--forest .rb-sg__card-bg  { background-color: #0e1c0e; }
  .rb-sg__card--amber  .rb-sg__card-bg  { background-color: #1e0f06; }
  .rb-sg__card--slate  .rb-sg__card-bg  { background-color: #0d1220; }
  .rb-sg__card--smoke  .rb-sg__card-bg  { background-color: #0a0a0a; }

  .rb-sg__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.92) 0%,
      rgba(0,0,0,0.50) 45%,
      rgba(0,0,0,0.10) 100%
    );
    transition: opacity 0.35s ease;
    z-index: 1;
  }

  .rb-sg__card:hover .rb-sg__card-overlay {
    opacity: 0.85;
  }

  .rb-sg__card-body {
    position: relative;
    z-index: 2;
    padding: 0 28px 36px;
    width: 100%;
    transform: translateY(8px);
    transition: transform 0.35s ease;
  }

  .rb-sg__card:hover .rb-sg__card-body {
    transform: translateY(0);
  }

  .rb-sg__card-type {
    font-family: 'Oswald', sans-serif;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0 0 8px 0;
  }

  .rb-sg__card-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 6px 0;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .rb-sg__card-tagline {
    font-family: 'Lato', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.60);
    margin: 0 0 14px 0;
    line-height: 1.5;
  }

  .rb-sg__card-notes {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(201,169,110,0.75);
    margin: 0 0 20px 0;
  }

  .rb-sg__card-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Oswald', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    transition: color 0.22s ease, gap 0.22s ease;
  }

  .rb-sg__card:hover .rb-sg__card-cta {
    color: #c9a96e;
    gap: 14px;
  }

  .rb-sg__card-cta-arrow {
    width: 18px;
    height: 1px;
    background: currentColor;
    position: relative;
    transition: width 0.22s ease;
  }

  .rb-sg__card-cta-arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -3px;
    width: 6px;
    height: 6px;
    border-right: 1px solid currentColor;
    border-top: 1px solid currentColor;
    transform: rotate(45deg);
  }

  @media screen and (max-width: 1024px) {
    .rb-sg__grid { grid-template-columns: repeat(2, 1fr); }
    .rb-sg__card { min-height: 400px; }
  }

  @media screen and (max-width: 590px) {
    .rb-sg { padding: 80px 0 0; }
    .rb-sg__header { padding: 0 24px 48px; }
    .rb-sg__grid { grid-template-columns: 1fr; gap: 2px; }
    .rb-sg__card { min-height: 320px; }
    .rb-sg__card-body { padding: 0 22px 28px; }
  }
</style>

<div class="rb-sg index-section" data-section-id="{{ section.id }}" data-section-type="rb-scent-grid">

  <div class="rb-sg__header">
    {% if section.settings.eyebrow != blank %}
      <p class="rb-sg__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="rb-sg__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <p class="rb-sg__subtitle">{{ section.settings.subtitle | escape }}</p>
    {% endif %}
  </div>

  <div class="rb-sg__grid">
    {% for block in section.blocks %}
      {% assign scheme = block.settings.color_scheme | default: 'smoke' %}

      {% if block.settings.link != blank %}
        <a href="{{ block.settings.link }}" class="rb-sg__card rb-sg__card--{{ scheme }}" {{ block.shopify_attributes }}>
      {% else %}
        <div class="rb-sg__card rb-sg__card--{{ scheme }}" {{ block.shopify_attributes }}>
      {% endif %}

        {% if block.settings.image != blank %}
          <div class="rb-sg__card-bg lazyload"
            data-bgset="{{ block.settings.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' }}"
            data-sizes="auto"
            data-parent-fit="cover"
            style="background-image: url('{{ block.settings.image | img_url: '400x' }}');"></div>
        {% elsif block.settings.raw_image_url != blank %}
          <div class="rb-sg__card-bg" style="background-image: url('{{ block.settings.raw_image_url }}');"></div>
        {% else %}
          <div class="rb-sg__card-bg"></div>
        {% endif %}

        <div class="rb-sg__card-overlay"></div>

        <div class="rb-sg__card-body">
          {% if block.settings.product_type != blank %}
            <p class="rb-sg__card-type">{{ block.settings.product_type | escape }}</p>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="rb-sg__card-title">{{ block.settings.title | escape }}</h3>
          {% endif %}
          {% if block.settings.tagline != blank %}
            <p class="rb-sg__card-tagline">{{ block.settings.tagline | escape }}</p>
          {% endif %}
          {% if block.settings.notes != blank %}
            <p class="rb-sg__card-notes">{{ block.settings.notes | escape }}</p>
          {% endif %}
          {% if block.settings.cta_label != blank %}
            <span class="rb-sg__card-cta">
              {{ block.settings.cta_label | escape }}
              <span class="rb-sg__card-cta-arrow" aria-hidden="true"></span>
            </span>
          {% endif %}
        </div>

      {% if block.settings.link != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

</div>

{% schema %}
{
  "name": "Scent Collection Grid",
  "class": "rb-sg-wrap",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow",  "label": "Eyebrow",  "default": "The Line" },
    { "type": "text", "id": "heading",  "label": "Heading",  "default": "Find Your Scent" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Every scent is a world. Find the one that's yours." }
  ],
  "blocks": [
    {
      "type": "scent",
      "name": "Scent Card",
      "settings": [
        {
          "type": "select",
          "id": "color_scheme",
          "label": "Color scheme (no image)",
          "options": [
            { "value": "forest", "label": "Forest — Great Wilderness" },
            { "value": "amber",  "label": "Amber — Legends" },
            { "value": "slate",  "label": "Slate — Leisure" },
            { "value": "smoke",  "label": "Smoke — Grief" }
          ],
          "default": "smoke"
        },
        { "type": "image_picker", "id": "image",         "label": "Card image" },
        { "type": "text",         "id": "raw_image_url", "label": "Image URL (CDN link)", "info": "Paste Shopify Files URL" },
        { "type": "text",         "id": "product_type",  "label": "Product type",  "default": "Beard Oil" },
        { "type": "text",         "id": "title",         "label": "Scent name",    "default": "Great Wilderness" },
        { "type": "text",         "id": "tagline",       "label": "Tagline",       "default": "The one that started it all." },
        { "type": "text",         "id": "notes",         "label": "Scent notes",   "default": "Cedar · Pine · Cold Morning Air" },
        { "type": "text",         "id": "cta_label",     "label": "CTA label",     "default": "Explore" },
        { "type": "url",          "id": "link",          "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Scent Collection Grid", "category": "Custom" }]
}
{% endschema %}
