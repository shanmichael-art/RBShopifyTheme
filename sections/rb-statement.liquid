<div class="rb-statement" data-section-id="{{ section.id }}" data-section-type="rb-statement">
  <div class="rb-statement-inner">
    {% if section.settings.kicker != blank %}
      <span class="rb-statement-kicker">{{ section.settings.kicker | upcase | escape }}</span>
    {% endif %}
    {% if section.settings.statement != blank %}
      <p class="rb-statement-text">{{ section.settings.statement | escape }}</p>
    {% endif %}
    {% if section.settings.context != blank %}
      <p class="rb-statement-context">{{ section.settings.context | escape }}</p>
    {% endif %}
    {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
      <a href="{{ section.settings.cta_link }}" class="rb-statement-cta">{{ section.settings.cta_label | escape }}</a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Brand Statement",
  "class": "rb-statement-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Eyebrow label",
      "default": "The Standard"
    },
    {
      "type": "text",
      "id": "statement",
      "label": "Main statement",
      "default": "Three minutes a day."
    },
    {
      "type": "textarea",
      "id": "context",
      "label": "Supporting copy",
      "default": "That's the difference between a beard you just have and one that actually says something about you."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Brand Statement",
      "category": "Custom"
    }
  ]
}
{% endschema %}
