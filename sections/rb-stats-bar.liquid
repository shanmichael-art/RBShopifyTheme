<div class="rb-stats-bar" data-section-id="{{ section.id }}" data-section-type="rb-stats-bar">
  <div class="wrapper">
    <div class="rb-stats-inner">
      {% for block in section.blocks %}
        <div class="rb-stat-item" {{ block.shopify_attributes }}>
          <span>{{ block.settings.stat | escape }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Stats Bar",
  "class": "index-section rb-stats-bar-section",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "stat",
          "label": "Stat text",
          "default": "★★★★★  4.9 / 5 Rating"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats Bar",
      "category": "Custom",
      "blocks": [
        { "type": "stat", "settings": { "stat": "★★★★★  4.9 / 5 Average Rating" } },
        { "type": "stat", "settings": { "stat": "2,500+ Verified Reviews" } },
        { "type": "stat", "settings": { "stat": "100% USA Handcrafted" } },
        { "type": "stat", "settings": { "stat": "Free Shipping Over $50" } }
      ]
    }
  ]
}
{% endschema %}
