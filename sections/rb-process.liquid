{% comment %} Royal Beardsmen — How It's Made / Process Section {% endcomment %}
<style>
  .rb-process {
    background: #0f0f0f;
    padding: 100px 40px;
    position: relative;
  }

  .rb-process__header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 72px;
  }

  .rb-process__eyebrow {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.30em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0 0 16px 0;
  }

  .rb-process__heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 3vw, 40px);
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  .rb-process__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    gap: 0;
  }

  .rb-process__steps::before {
    content: '';
    position: absolute;
    top: 28px;
    left: calc(16.66% + 10px);
    right: calc(16.66% + 10px);
    height: 1px;
    background: linear-gradient(to right, #c9a96e 0%, rgba(201,169,110,0.20) 50%, #c9a96e 100%);
    pointer-events: none;
  }

  .rb-process__step {
    text-align: center;
    padding: 0 32px;
    position: relative;
  }

  .rb-process__step-num {
    width: 56px;
    height: 56px;
    border: 1px solid rgba(201,169,110,0.35);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 28px;
    position: relative;
    z-index: 1;
    background: #0f0f0f;
    transition: border-color 0.25s ease, background 0.25s ease;
  }

  .rb-process__step:hover .rb-process__step-num {
    border-color: #c9a96e;
    background: rgba(201,169,110,0.06);
  }

  .rb-process__step-num span {
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: #c9a96e;
  }

  .rb-process__step-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 12px 0;
  }

  .rb-process__step-desc {
    font-family: 'Lato', sans-serif;
    font-size: 14px;
    line-height: 1.72;
    color: rgba(255,255,255,0.44);
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .rb-process { padding: 80px 24px; }
    .rb-process__steps {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .rb-process__steps::before { display: none; }
    .rb-process__step { padding: 0; text-align: left; display: flex; gap: 24px; align-items: flex-start; }
    .rb-process__step-num { flex-shrink: 0; margin: 0; }
    .rb-process__step-body { flex: 1; padding-top: 12px; }
  }
</style>

<div class="rb-process index-section" data-section-id="{{ section.id }}" data-section-type="rb-process">

  <div class="rb-process__header">
    {% if section.settings.eyebrow != blank %}
      <p class="rb-process__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="rb-process__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
  </div>

  <div class="rb-process__steps">
    {% for block in section.blocks %}
      <div class="rb-process__step" {{ block.shopify_attributes }}>
        <div class="rb-process__step-num">
          <span>0{{ forloop.index }}</span>
        </div>
        <div class="rb-process__step-body">
          {% if block.settings.title != blank %}
            <h3 class="rb-process__step-title">{{ block.settings.title | escape }}</h3>
          {% endif %}
          {% if block.settings.desc != blank %}
            <p class="rb-process__step-desc">{{ block.settings.desc | escape }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

</div>

{% schema %}
{
  "name": "How It's Made",
  "class": "rb-process-wrap",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How It's Made" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Small Batches. Real Care." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text",     "id": "title", "label": "Title",       "default": "Sourced" },
        { "type": "textarea", "id": "desc",  "label": "Description", "default": "We select premium carrier oils and organic botanicals for their performance — not because they're cheap." }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It's Made",
      "category": "Custom",
      "blocks": [
        { "type": "step", "settings": { "title": "Sourced",   "desc": "We select premium carrier oils and organic botanicals for their performance on beard hair and skin — not because they're cheap." } },
        { "type": "step", "settings": { "title": "Blended",   "desc": "Every formula is blended in small batches in Spring Hill, Florida. One batch at a time. Every time." } },
        { "type": "step", "settings": { "title": "Delivered", "desc": "Filled, sealed, and inspected by hand. In a 2oz bottle — because cutting you short was never an option." } }
      ]
    }
  ]
}
{% endschema %}
