<div class="rb-scent-feature" data-section-id="{{ section.id }}" data-section-type="rb-scent-feature">
  <div class="rb-scent-inner">
    {% if section.settings.eyebrow != blank %}
      <p class="rb-scent-eyebrow">{{ section.settings.eyebrow | upcase | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="rb-scent-heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.scent_name != blank %}
      <p class="rb-scent-name">{{ section.settings.scent_name | upcase | escape }}</p>
    {% endif %}
    {% if section.settings.description != blank %}
      <p class="rb-scent-description">{{ section.settings.description | escape }}</p>
    {% endif %}
    {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
      <a href="{{ section.settings.cta_link }}" class="rb-scent-cta btn">
        {{ section.settings.cta_label | escape }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Scent Feature",
  "class": "index-section rb-scent-feature-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Signature Scent"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "A scent has a soul."
    },
    {
      "type": "text",
      "id": "scent_name",
      "label": "Scent name",
      "default": "Great Wilderness"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Scent description",
      "default": "Cedar. Pine. Morning air before the rest of the world wakes up. Close your eyes — you already know this place. This is where you belong."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button text",
      "default": "Shop Great Wilderness"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Scent Feature",
      "category": "Custom"
    }
  ]
}
{% endschema %}
