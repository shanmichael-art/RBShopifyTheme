<div class="rb-scent-world" data-section-id="{{ section.id }}" data-section-type="rb-scent-world">

  {% comment %} Panel One {% endcomment %}
  <div class="rb-sw-panel rb-sw-panel--one">
    {% if section.settings.panel1_image != blank %}
      <div class="rb-sw-bg lazyload"
        data-bgset="{{ section.settings.panel1_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' }}"
        data-sizes="auto"
        data-parent-fit="cover">
      </div>
    {% elsif section.settings.panel1_raw_url != blank %}
      <div class="rb-sw-bg" style="background-image: url('{{ section.settings.panel1_raw_url | escape }}');"></div>
    {% else %}
      <div class="rb-sw-bg rb-sw-gradient--humidor"></div>
    {% endif %}
    <div class="rb-sw-overlay"></div>
    <div class="rb-sw-content">
      {% if section.settings.panel1_eyebrow != blank %}
        <p class="rb-sw-eyebrow">{{ section.settings.panel1_eyebrow | upcase | escape }}</p>
      {% endif %}
      {% if section.settings.panel1_name != blank %}
        <h2 class="rb-sw-name">{{ section.settings.panel1_name | escape }}</h2>
      {% endif %}
      {% if section.settings.panel1_notes != blank %}
        <p class="rb-sw-notes">{{ section.settings.panel1_notes | escape }}</p>
      {% endif %}
      {% if section.settings.panel1_description != blank %}
        <p class="rb-sw-desc">{{ section.settings.panel1_description | escape }}</p>
      {% endif %}
      {% if section.settings.panel1_cta_label != blank and section.settings.panel1_cta_link != blank %}
        <a href="{{ section.settings.panel1_cta_link }}" class="rb-sw-cta">{{ section.settings.panel1_cta_label | escape }}</a>
      {% endif %}
    </div>
  </div>

  {% comment %} Panel Two {% endcomment %}
  <div class="rb-sw-panel rb-sw-panel--two">
    {% if section.settings.panel2_image != blank %}
      <div class="rb-sw-bg lazyload"
        data-bgset="{{ section.settings.panel2_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' }}"
        data-sizes="auto"
        data-parent-fit="cover">
      </div>
    {% elsif section.settings.panel2_raw_url != blank %}
      <div class="rb-sw-bg" style="background-image: url('{{ section.settings.panel2_raw_url | escape }}');"></div>
    {% else %}
      <div class="rb-sw-bg rb-sw-gradient--bonfire"></div>
    {% endif %}
    <div class="rb-sw-overlay"></div>
    <div class="rb-sw-content">
      {% if section.settings.panel2_eyebrow != blank %}
        <p class="rb-sw-eyebrow">{{ section.settings.panel2_eyebrow | upcase | escape }}</p>
      {% endif %}
      {% if section.settings.panel2_name != blank %}
        <h2 class="rb-sw-name">{{ section.settings.panel2_name | escape }}</h2>
      {% endif %}
      {% if section.settings.panel2_notes != blank %}
        <p class="rb-sw-notes">{{ section.settings.panel2_notes | escape }}</p>
      {% endif %}
      {% if section.settings.panel2_description != blank %}
        <p class="rb-sw-desc">{{ section.settings.panel2_description | escape }}</p>
      {% endif %}
      {% if section.settings.panel2_cta_label != blank and section.settings.panel2_cta_link != blank %}
        <a href="{{ section.settings.panel2_cta_link }}" class="rb-sw-cta">{{ section.settings.panel2_cta_label | escape }}</a>
      {% endif %}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Scent World Panels",
  "class": "rb-scent-world-section",
  "settings": [
    {
      "type": "header",
      "content": "Panel One"
    },
    {
      "type": "image_picker",
      "id": "panel1_image",
      "label": "Panel 1 background image"
    },
    {
      "type": "text",
      "id": "panel1_raw_url",
      "label": "Panel 1 image URL (CDN)"
    },
    {
      "type": "text",
      "id": "panel1_eyebrow",
      "label": "Panel 1 eyebrow",
      "default": "Beard Oil"
    },
    {
      "type": "text",
      "id": "panel1_name",
      "label": "Panel 1 scent name",
      "default": "El Humidor"
    },
    {
      "type": "text",
      "id": "panel1_notes",
      "label": "Panel 1 scent notes",
      "default": "Honey · Vanilla · Black Pepper"
    },
    {
      "type": "text",
      "id": "panel1_description",
      "label": "Panel 1 description",
      "default": "The cigar lounge in a bottle. Rich, warm, and uncompromising."
    },
    {
      "type": "text",
      "id": "panel1_cta_label",
      "label": "Panel 1 button text",
      "default": "Shop El Humidor"
    },
    {
      "type": "url",
      "id": "panel1_cta_link",
      "label": "Panel 1 button link"
    },
    {
      "type": "header",
      "content": "Panel Two"
    },
    {
      "type": "image_picker",
      "id": "panel2_image",
      "label": "Panel 2 background image"
    },
    {
      "type": "text",
      "id": "panel2_raw_url",
      "label": "Panel 2 image URL (CDN)"
    },
    {
      "type": "text",
      "id": "panel2_eyebrow",
      "label": "Panel 2 eyebrow",
      "default": "Beard Oil"
    },
    {
      "type": "text",
      "id": "panel2_name",
      "label": "Panel 2 scent name",
      "default": "Bonfire Brandy"
    },
    {
      "type": "text",
      "id": "panel2_notes",
      "label": "Panel 2 scent notes",
      "default": "Smoked Wood · Rich Brandy · Warm Vanilla"
    },
    {
      "type": "text",
      "id": "panel2_description",
      "label": "Panel 2 description",
      "default": "Campfire smoke, aged brandy, and something you can't quite name. This one stays with you."
    },
    {
      "type": "text",
      "id": "panel2_cta_label",
      "label": "Panel 2 button text",
      "default": "Shop Bonfire Brandy"
    },
    {
      "type": "url",
      "id": "panel2_cta_link",
      "label": "Panel 2 button link"
    }
  ],
  "presets": [
    {
      "name": "Scent World Panels",
      "category": "Custom"
    }
  ]
}
{% endschema %}
