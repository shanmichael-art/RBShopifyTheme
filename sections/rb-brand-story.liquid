<div class="rb-brand-story" data-section-id="{{ section.id }}" data-section-type="rb-brand-story">
  <div class="rb-brand-story-grid">

    <div class="rb-bs-visual">
      {% if section.settings.image != blank %}
        <div class="rb-bs-img lazyload"
          data-bgset="{{ section.settings.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' }}"
          data-sizes="auto"
          data-parent-fit="cover">
        </div>
      {% elsif section.settings.raw_image_url != blank %}
        <div class="rb-bs-img" style="background-image: url('{{ section.settings.raw_image_url | escape }}');"></div>
      {% else %}
        <div class="rb-bs-img rb-bs-placeholder">
          <div class="rb-bs-placeholder-inner">
            <span class="rb-bs-placeholder-text">Spring Hill, FL</span>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="rb-bs-copy">
      {% if section.settings.eyebrow != blank %}
        <p class="rb-bs-eyebrow">{{ section.settings.eyebrow | upcase | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="rb-bs-heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.body != blank %}
        <div class="rb-bs-body rte">{{ section.settings.body }}</div>
      {% endif %}
      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <a href="{{ section.settings.cta_link }}" class="rb-bs-cta">{{ section.settings.cta_label | escape }}</a>
      {% endif %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Brand Story",
  "class": "rb-brand-story-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story image"
    },
    {
      "type": "text",
      "id": "raw_image_url",
      "label": "Story image URL (CDN)"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Image left" },
        { "value": "right", "label": "Image right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We got tired of bad beard oil."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy",
      "default": "<p>The industry standard is a 1oz bottle of watered-down oil with a label that costs more than what's inside. We built Royal Beardsmen because we couldn't find a product we actually wanted to use every day.</p><p>Every formula is handcrafted in Spring Hill, Florida. Small batches. Real ingredients. If it's not good enough to put on our own face — it doesn't ship.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Brand Story",
      "category": "Custom"
    }
  ]
}
{% endschema %}
