{% comment %}
  Royal Beardsmen — Premium Footer
  4-column: Brand + About | Shop | Support | Newsletter
  Preserves original footer schema key for backwards compat.
{% endcomment %}

<footer class="rb-section rb-footer" role="contentinfo" data-section-id="{{ section.id }}" data-section-type="footer-section">
  <div class="rb-container">

    <div class="rb-footer__grid">

      {%- comment -%} Column 1: Brand {%- endcomment -%}
      <div>
        <p class="rb-footer__brand-name">
          Royal <span>Beardsmen</span>
        </p>
        <p class="rb-footer__brand-desc">
          {{ section.settings.brand_description | default: 'Premium beard care crafted for men who hold themselves to a higher standard. Handmade in the USA.' }}
        </p>
        <div class="rb-footer__social">
          {% if settings.social_instagram_link != blank %}
            <a href="{{ settings.social_instagram_link | escape }}" class="rb-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if settings.social_facebook_link != blank %}
            <a href="{{ settings.social_facebook_link | escape }}" class="rb-footer__social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_twitter_link != blank %}
            <a href="{{ settings.social_twitter_link | escape }}" class="rb-footer__social-link" aria-label="X / Twitter" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4l16 16M4 20L20 4"/></svg>
            </a>
          {% endif %}
          {% if settings.social_youtube_link != blank %}
            <a href="{{ settings.social_youtube_link | escape }}" class="rb-footer__social-link" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.45A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.45a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      {%- comment -%} Column 2: Shop links from link_list {%- endcomment -%}
      <div>
        <h3 class="rb-footer__col-title">{{ section.settings.shop_col_title | default: 'Shop' }}</h3>
        {% if linklists[section.settings.footer_shop_list].links.size > 0 %}
          <ul class="rb-footer__links">
            {% for link in linklists[section.settings.footer_shop_list].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="rb-footer__links">
            <li><a href="{{ routes.all_products_collection_url }}">All Products</a></li>
            <li><a href="{{ routes.collections_url }}/beard-oils">Beard Oils</a></li>
            <li><a href="{{ routes.collections_url }}/beard-balms">Beard Balms</a></li>
            <li><a href="{{ routes.collections_url }}/beard-wash">Beard Wash</a></li>
            <li><a href="{{ routes.collections_url }}/bundles">Bundles</a></li>
            <li><a href="{{ routes.collections_url }}/accessories">Accessories</a></li>
          </ul>
        {% endif %}
      </div>

      {%- comment -%} Column 3: Support / company links {%- endcomment -%}
      <div>
        <h3 class="rb-footer__col-title">{{ section.settings.support_col_title | default: 'Support' }}</h3>
        {% if linklists[section.settings.footer_link_list].links.size > 0 %}
          <ul class="rb-footer__links">
            {% for link in linklists[section.settings.footer_link_list].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="rb-footer__links">
            <li><a href="/pages/about">Our Story</a></li>
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/shipping">Shipping &amp; Returns</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
            <li><a href="/blogs/news">Journal</a></li>
          </ul>
        {% endif %}
      </div>

      {%- comment -%} Column 4: Newsletter {%- endcomment -%}
      <div>
        <h3 class="rb-footer__col-title">{{ section.settings.newsletter_title | default: 'Join the Brotherhood' }}</h3>
        <p style="font-family:var(--font-body);font-size:0.875rem;font-weight:300;line-height:1.65;color:var(--rb-text-dim);margin:0 0 0.25rem;">
          {{ section.settings.newsletter_desc | default: 'Grooming tips, early access to new drops, and member-only discounts.' }}
        </p>
        {% form 'customer', class: 'rb-footer__newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label for="rb-footer-email" class="rb-visually-hidden">Email address</label>
          <input
            type="email"
            id="rb-footer-email"
            name="contact[email]"
            class="rb-footer__newsletter-input"
            placeholder="Your email address"
            required
            autocomplete="email"
          >
          <button type="submit" class="rb-footer__newsletter-btn">
            Join
          </button>
        {% endform %}
        <p style="margin-top:0.75rem;font-family:var(--font-body);font-size:0.6875rem;color:var(--rb-text-dim);">
          No spam. Unsubscribe anytime.
        </p>
      </div>

    </div>

    <div class="rb-footer__bottom">
      <p class="rb-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      <div style="display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
        <a href="/policies/privacy-policy" style="font-family:var(--font-body);font-size:0.75rem;color:var(--rb-text-dim);text-decoration:none;transition:color 150ms;">Privacy</a>
        <a href="/policies/terms-of-service" style="font-family:var(--font-body);font-size:0.75rem;color:var(--rb-text-dim);text-decoration:none;transition:color 150ms;">Terms</a>
        <a href="/policies/refund-policy" style="font-family:var(--font-body);font-size:0.75rem;color:var(--rb-text-dim);text-decoration:none;transition:color 150ms;">Refund Policy</a>
      </div>
      {% unless shop.enabled_payment_types == empty %}
        <div class="rb-footer__payment-icons">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      {% endunless %}
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand column"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium beard care crafted for men who hold themselves to a higher standard. Handmade in the USA."
    },
    {
      "type": "header",
      "content": "Shop column"
    },
    {
      "type": "text",
      "id": "shop_col_title",
      "label": "Shop column title",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "footer_shop_list",
      "label": "Shop menu",
      "info": "Leave blank to use defaults"
    },
    {
      "type": "header",
      "content": "Support column"
    },
    {
      "type": "text",
      "id": "support_col_title",
      "label": "Support column title",
      "default": "Support"
    },
    {
      "type": "link_list",
      "id": "footer_link_list",
      "label": "Support / company menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Newsletter column"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter column title",
      "default": "Join the Brotherhood"
    },
    {
      "type": "textarea",
      "id": "newsletter_desc",
      "label": "Newsletter description",
      "default": "Grooming tips, early access to new drops, and member-only discounts."
    }
  ]
}
{% endschema %}
