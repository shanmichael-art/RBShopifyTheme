{% comment %}
  Royal Beardsmen — Cinematic Hero Section
  Full-viewport dark hero with gold CTA.
  Schema: bg image, headline, sub, CTA text/url, eyebrow text
{% endcomment %}

<section class="rb-section rb-hero" data-section-id="{{ section.id }}" data-section-type="rb-hero">
  <div class="rb-hero__bg">
    {% if section.settings.bg_image %}
      <img
        src="{{ section.settings.bg_image | image_url: width: 2400 }}"
        srcset="{{ section.settings.bg_image | image_url: width: 800 }} 800w,
                {{ section.settings.bg_image | image_url: width: 1400 }} 1400w,
                {{ section.settings.bg_image | image_url: width: 2400 }} 2400w"
        sizes="100vw"
        alt="{{ section.settings.headline | escape }}"
        width="{{ section.settings.bg_image.width }}"
        height="{{ section.settings.bg_image.height }}"
        loading="eager"
        fetchpriority="high"
      >
    {% else %}
      {%- comment -%} Fallback gradient when no image is set {%- endcomment -%}
      <div style="width:100%;height:100%;background:linear-gradient(150deg,#1E1B18 0%,#0D0D0B 60%,#161412 100%);"></div>
    {% endif %}
  </div>
  <div class="rb-hero__overlay"></div>

  <div class="rb-hero__content">
    <div class="rb-hero__eyebrow rb-reveal">
      <span class="rb-hero__eyebrow-line"></span>
      <span class="rb-hero__eyebrow-text">{{ section.settings.eyebrow | default: 'Premium Grooming' }}</span>
    </div>

    <h1 class="rb-hero__headline rb-reveal rb-reveal--delay-1">
      {{ section.settings.headline | default: 'Crafted for the<br><em>Modern King</em>' }}
    </h1>

    {% if section.settings.subheadline != blank %}
      <p class="rb-hero__sub rb-reveal rb-reveal--delay-2">
        {{ section.settings.subheadline }}
      </p>
    {% endif %}

    <div class="rb-hero__actions rb-reveal rb-reveal--delay-3">
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}"
         class="rb-btn rb-btn--primary">
        {{ section.settings.cta_text | default: 'Shop the Collection' }}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      {% if section.settings.cta2_text != blank %}
        <a href="{{ section.settings.cta2_url | default: '/pages/about' }}"
           class="rb-btn rb-btn--ghost">
          {{ section.settings.cta2_text }}
        </a>
      {% endif %}
    </div>
  </div>

  <div class="rb-hero__scroll" aria-hidden="true">
    <span class="rb-hero__scroll-text">Scroll</span>
    <span class="rb-hero__scroll-line"></span>
  </div>
</section>

{% schema %}
{
  "name": "RB — Hero",
  "tag": "section",
  "class": "rb-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "info": "Recommended: 2400×1600px, dark atmospheric photo. Models in lifestyle settings work best."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Premium Grooming",
      "info": "Small uppercase text above headline"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Crafted for the<br><em>Modern King</em>",
      "info": "Use <br> for line breaks and <em> for gold italic text"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Premium beard oils, balms, and grooming essentials formulated for men who hold themselves to a higher standard."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Secondary CTA (optional)"
    },
    {
      "type": "text",
      "id": "cta2_text",
      "label": "Ghost button text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Ghost button URL",
      "default": "/pages/about"
    }
  ],
  "presets": [
    {
      "name": "RB — Hero",
      "category": "Royal Beardsmen"
    }
  ]
}
{% endschema %}
