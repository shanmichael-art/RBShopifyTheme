<div class="rb-hero" data-section-id="{{ section.id }}" data-section-type="rb-hero">
  {% if section.settings.image != blank %}
    <div class="rb-hero-bg lazyload"
      data-bgset="{{ section.settings.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' }}"
      data-sizes="auto"
      data-parent-fit="cover">
    </div>
  {% elsif section.settings.raw_image_url != blank %}
    <div class="rb-hero-bg" style="background-image: url('{{ section.settings.raw_image_url | escape }}');"></div>
  {% else %}
    <div class="rb-hero-bg rb-hero-gradient"></div>
  {% endif %}

  <div class="rb-hero-overlay"></div>

  <div class="rb-hero-content">
    {% if section.settings.eyebrow != blank %}
      <p class="rb-hero-eyebrow">{{ section.settings.eyebrow | upcase | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h1 class="rb-hero-heading">{{ section.settings.heading | escape }}</h1>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="rb-hero-sub">{{ section.settings.subheading | escape }}</p>
    {% endif %}
    <div class="rb-hero-actions">
      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <a href="{{ section.settings.cta_link }}" class="rb-hero-cta rb-hero-cta--primary">{{ section.settings.cta_label | escape }}</a>
      {% endif %}
      {% if section.settings.cta2_label != blank and section.settings.cta2_link != blank %}
        <a href="{{ section.settings.cta2_link }}" class="rb-hero-cta rb-hero-cta--ghost">{{ section.settings.cta2_label | escape }}</a>
      {% endif %}
    </div>
  </div>

  <div class="rb-hero-scroll">
    <div class="rb-hero-scroll-line"></div>
  </div>
</div>

{% schema %}
{
  "name": "RB Hero",
  "class": "rb-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero background image"
    },
    {
      "type": "text",
      "id": "raw_image_url",
      "label": "Hero image URL (CDN)",
      "info": "Paste a Shopify CDN URL for images uploaded via Shopify Files."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Royal Beardsmen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "The Beard Deserves Better."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium beard care. Handcrafted in small batches in Spring Hill, Florida."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button text",
      "default": "Shop Beard Oils"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Secondary button text",
      "default": "Find Your Scent"
    },
    {
      "type": "url",
      "id": "cta2_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "RB Hero",
      "category": "Custom"
    }
  ]
}
{% endschema %}
