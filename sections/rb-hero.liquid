{% comment %} Royal Beardsmen — Full-Screen Hero {% endcomment %}
<style>
  .rb-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #080808;
  }

  .rb-hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-repeat: no-repeat;
    background-position: {{ section.settings.bg_position | default: 'center center' }};
    transform: scale(1.03);
    transition: transform 6s ease-out;
  }

  .rb-hero.is-loaded .rb-hero__bg {
    transform: scale(1);
  }

  .rb-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to right, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.55) 55%, rgba(0,0,0,0.08) 100%),
      linear-gradient(to top, rgba(0,0,0,0.50) 0%, transparent 40%);
  }

  .rb-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 180px 60px 100px;
  }

  .rb-hero__inner {
    max-width: 620px;
  }

  .rb-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 28px 0;
  }

  .rb-hero__eyebrow-line {
    width: 36px;
    height: 1px;
    background: #c9a96e;
    flex-shrink: 0;
  }

  .rb-hero__eyebrow-text {
    font-family: 'Oswald', sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: #c9a96e;
    margin: 0;
  }

  .rb-hero__headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(48px, 6.5vw, 88px);
    font-weight: 700;
    line-height: 1.04;
    color: #ffffff;
    margin: 0 0 24px 0;
    letter-spacing: -0.02em;
  }

  .rb-hero__sub {
    font-family: 'Lato', sans-serif;
    font-size: 17px;
    line-height: 1.70;
    color: rgba(255,255,255,0.72);
    margin: 0 0 44px 0;
    max-width: 420px;
  }

  .rb-hero__actions {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    margin-bottom: 52px;
  }

  .rb-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 38px;
    background: #c9a96e;
    color: #111111 !important;
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: background 0.22s ease, transform 0.18s ease;
    white-space: nowrap;
    outline: none;
  }

  .rb-hero__btn:hover {
    background: #b89455;
    transform: translateY(-1px);
  }

  .rb-hero__btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 36px;
    background: transparent;
    color: rgba(255,255,255,0.85) !important;
    border: 1px solid rgba(255,255,255,0.28);
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.22s ease, color 0.22s ease;
    white-space: nowrap;
  }

  .rb-hero__btn-ghost:hover {
    border-color: #c9a96e;
    color: #c9a96e !important;
  }

  .rb-hero__proof {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    row-gap: 6px;
  }

  .rb-hero__proof-chunk {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-right: 18px;
    margin-right: 18px;
    border-right: 1px solid rgba(255,255,255,0.16);
  }

  .rb-hero__proof-chunk:last-child {
    border-right: none;
    padding-right: 0;
    margin-right: 0;
  }

  .rb-hero__proof-stars {
    color: #c9a96e;
    font-size: 12px;
    letter-spacing: 1.5px;
  }

  .rb-hero__proof-label {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.48);
    letter-spacing: 0.03em;
  }

  .rb-hero__scroll {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: rbHeroScrollFadeIn 0.8s ease 1.4s forwards;
    cursor: default;
  }

  .rb-hero__scroll-word {
    font-family: 'Oswald', sans-serif;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.32);
  }

  .rb-hero__scroll-track {
    width: 1px;
    height: 50px;
    background: rgba(255,255,255,0.15);
    position: relative;
    overflow: hidden;
  }

  .rb-hero__scroll-dot {
    position: absolute;
    top: -8px;
    left: -2px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #c9a96e;
    animation: rbHeroScrollDot 1.8s ease-in-out infinite;
  }

  @keyframes rbHeroScrollFadeIn {
    to { opacity: 1; }
  }

  @keyframes rbHeroScrollDot {
    0%   { top: -8px; opacity: 0; }
    15%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { top: 54px; opacity: 0; }
  }

  @media screen and (max-width: 768px) {
    .rb-hero {
      align-items: flex-end;
    }
    .rb-hero__overlay {
      background:
        linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.65) 45%, rgba(0,0,0,0.12) 100%);
    }
    .rb-hero__content {
      padding: 100px 28px 64px;
    }
    .rb-hero__inner {
      max-width: 100%;
    }
    .rb-hero__headline {
      font-size: clamp(38px, 10vw, 56px);
    }
    .rb-hero__sub {
      font-size: 15px;
      max-width: 100%;
    }
    .rb-hero__btn,
    .rb-hero__btn-ghost {
      padding: 14px 28px;
      font-size: 11px;
    }
    .rb-hero__scroll {
      display: none;
    }
  }
</style>

<div class="rb-hero" id="RbHero" data-section-id="{{ section.id }}" data-section-type="rb-hero">

  {% if section.settings.bg_image != blank %}
    <div class="rb-hero__bg lazyload"
      data-bgset="{{ section.settings.bg_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' }}"
      data-sizes="auto"
      data-parent-fit="cover"
      style="background-image: url('{{ section.settings.bg_image | img_url: '800x' }}');
             background-position: {{ section.settings.bg_position | default: 'center center' }};"></div>
  {% else %}
    <div class="rb-hero__bg" style="background: linear-gradient(135deg, #0c0c0c 0%, #1c1408 55%, #0d0b04 100%);"></div>
  {% endif %}

  <div class="rb-hero__overlay"></div>

  <div class="rb-hero__content">
    <div class="rb-hero__inner">

      {% if section.settings.eyebrow != blank %}
        <div class="rb-hero__eyebrow">
          <span class="rb-hero__eyebrow-line"></span>
          <p class="rb-hero__eyebrow-text">{{ section.settings.eyebrow | escape }}</p>
        </div>
      {% endif %}

      {% if section.settings.headline != blank %}
        <h1 class="rb-hero__headline">{{ section.settings.headline | escape }}</h1>
      {% endif %}

      {% if section.settings.subtext != blank %}
        <p class="rb-hero__sub">{{ section.settings.subtext | escape }}</p>
      {% endif %}

      <div class="rb-hero__actions">
        {% if section.settings.btn_label != blank %}
          <a href="{{ section.settings.btn_link }}" class="rb-hero__btn">
            {{ section.settings.btn_label | escape }}
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
              <path d="M1 5h12M8.5 1l4.5 4-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}
        {% if section.settings.ghost_btn_label != blank %}
          <a href="{{ section.settings.ghost_btn_link }}" class="rb-hero__btn-ghost">
            {{ section.settings.ghost_btn_label | escape }}
          </a>
        {% endif %}
      </div>

      {% if section.settings.show_proof %}
        <div class="rb-hero__proof">
          <div class="rb-hero__proof-chunk">
            <span class="rb-hero__proof-stars">★★★★★</span>
            <span class="rb-hero__proof-label">{{ section.settings.proof_rating | default: '4.9' }}</span>
          </div>
          <div class="rb-hero__proof-chunk">
            <span class="rb-hero__proof-label">{{ section.settings.proof_reviews | default: '2,500+ Reviews' }}</span>
          </div>
          <div class="rb-hero__proof-chunk">
            <span class="rb-hero__proof-label">{{ section.settings.proof_badge | default: 'USA Handcrafted' }}</span>
          </div>
        </div>
      {% endif %}

    </div>
  </div>

  {% if section.settings.show_scroll %}
    <div class="rb-hero__scroll" aria-hidden="true">
      <span class="rb-hero__scroll-word">Scroll</span>
      <div class="rb-hero__scroll-track">
        <div class="rb-hero__scroll-dot"></div>
      </div>
    </div>
  {% endif %}

</div>

<script>
  (function(){
    var el = document.getElementById('RbHero');
    if(!el) return;
    setTimeout(function(){ el.classList.add('is-loaded'); }, 100);
  })();
</script>

{% schema %}
{
  "name": "Full-Screen Hero",
  "class": "rb-hero-wrap",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "info": "Recommended: 2400×1600px, dark moody lifestyle photo"
    },
    {
      "type": "select",
      "id": "bg_position",
      "label": "Image focal point",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ],
      "default": "center center"
    },
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "eyebrow",  "label": "Eyebrow",   "default": "Royal Beardsmen" },
    { "type": "text", "id": "headline", "label": "Headline",  "default": "The Beard Deserves Better." },
    { "type": "text", "id": "subtext",  "label": "Subtext",   "default": "Handcrafted beard oil for the man who doesn't settle." },
    { "type": "header", "content": "Primary Button" },
    { "type": "text", "id": "btn_label",      "label": "Label", "default": "Shop the Line" },
    { "type": "url",  "id": "btn_link",       "label": "Link" },
    { "type": "header", "content": "Secondary Button" },
    { "type": "text", "id": "ghost_btn_label", "label": "Label", "default": "Find Your Scent" },
    { "type": "url",  "id": "ghost_btn_link",  "label": "Link" },
    { "type": "header", "content": "Social Proof" },
    { "type": "checkbox", "id": "show_proof",    "label": "Show proof line",  "default": true },
    { "type": "text",     "id": "proof_rating",  "label": "Rating",           "default": "4.9" },
    { "type": "text",     "id": "proof_reviews", "label": "Reviews label",    "default": "2,500+ Reviews" },
    { "type": "text",     "id": "proof_badge",   "label": "Badge text",       "default": "USA Handcrafted" },
    { "type": "header", "content": "Extras" },
    { "type": "checkbox", "id": "show_scroll", "label": "Show scroll indicator", "default": true }
  ],
  "presets": [{ "name": "Full-Screen Hero", "category": "Custom" }]
}
{% endschema %}
